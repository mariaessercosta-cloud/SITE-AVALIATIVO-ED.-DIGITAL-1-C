<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vício em Celular</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header role="banner">
        <nav aria-label="Menu principal">
            <h1>Vício em Celular</h1>
            <button id="increase-font" aria-label="Aumentar fonte">A+</button>
            <button id="decrease-font" aria-label="Diminuir fonte">A-</button>
            <button id="toggle-contrast" aria-label="Ativar alto contraste">Contraste</button>
        </nav>
    </header>

    <main role="main">
        <!-- Seção de Introdução -->
        <section id="intro" aria-labelledby="intro-title">
            <h2 id="intro-title">O Impacto do Vício em Celular</h2>
            <p>Descubra como o uso excessivo de celulares afeta a saúde mental e física.</p>
        </section>

        <!-- Seção de Cards informativos -->
        <section id="cards" aria-labelledby="cards-title">
            <h2 id="cards-title">Fatos Importantes</h2>
            <div class="cards-container" role="list">
                <!-- Cards serão renderizados pelo JS -->
            </div>
        </section>

        <!-- Seção de Carrossel -->
        <section id="carousel-section" aria-labelledby="carousel-title">
            <h2 id="carousel-title">Dicas para Reduzir o Uso</h2>
            <div class="carousel">
                <button class="carousel-btn prev" aria-label="Slide anterior">&#10094;</button>
                <div class="carousel-track">
                    <!-- Slides serão renderizados pelo JS -->
                </div>
                <button class="carousel-btn next" aria-label="Próximo slide">&#10095;</button>
            </div>
        </section>

        <!-- Seção de Acordeão -->
        <section id="accordion-section" aria-labelledby="accordion-title">
            <h2 id="accordion-title">Perguntas Frequentes</h2>
            <div class="accordion-container">
                <!-- Acordeões serão renderizados pelo JS -->
            </div>
        </section>
    </main>

    <footer role="contentinfo">
        <p>&copy; 2026 Conscientização sobre o Vício em Celular</p>
    </footer>

    <script src="script.js" defer></script>
</body>
</html>
